    // --- 화면 전환 스위치 ---
    function changeScreen(screenName) {
        currentScreen = screenName;
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(`${screenName}-screen`).classList.add('active');

        const backBtn = document.getElementById('back-btn');
        const scoreBoard = document.getElementById('current-score-board');
        const resetBtn = document.getElementById('reset-btn');

        if(screenName === 'lobby' || screenName === 'tutorial') {
            backBtn.style.display = 'none';
            scoreBoard.style.display = 'none';
            resetBtn.style.display = 'none';
        } else if(screenName === 'game') {
            backBtn.style.display = 'flex';
            scoreBoard.style.display = 'block';
            resetBtn.style.display = activeTrueEndingWatchMode ? 'none' : 'flex';
            refreshScoreDisplay();
        } else if(screenName === 'book') {
            backBtn.style.display = 'flex';
            scoreBoard.style.display = 'block';
            resetBtn.style.display = 'none';
            refreshScoreDisplay();
        }
    }

    function refreshScoreDisplay() {
        document.getElementById('current-score-board').innerText = `성취도: ${savedEndings.length} / 31`;
    }

    function pressStart() {
        if(activeTrueEndingWatchMode) { changeScreen('game'); return; }
        if(!isTutorialDone) { changeScreen('tutorial'); } 
        else { changeScreen('game'); }
    }

    function exitTutorial() {
        isTutorialDone = true;
        changeScreen('game');
    }

    // --- 도움말 전용 내부 중앙 팝업창 연동 ---
    function openInfoModal(title, text) {
        document.getElementById('info-modal-title').innerText = `🔬 계측 가이드: ${title}`;
        document.getElementById('info-modal-msg').innerText = text;
        document.getElementById('info-modal-overlay').style.display = 'flex';
    }

    function closeInfoModal() {
        document.getElementById('info-modal-overlay').style.display = 'none';
    }

    // --- 직접 클릭하여 타이핑 입력하는 마운트 코어 ---
    function promptDirectInput(id, message, scaleFactor, precision) {
        const slider = document.getElementById(id);
        document.getElementById('input-modal-title').innerText = "수치 직접 제어";
        document.getElementById('input-modal-msg').innerText = message;
        
        const currentVal = (parseFloat(slider.value) / scaleFactor).toFixed(precision);
        const inputField = document.getElementById('input-modal-field');
        inputField.value = currentVal;
        
        document.getElementById('input-modal-overlay').style.display = 'flex';
        inputField.focus();

        document.getElementById('input-modal-submit').onclick = function() {
            let typedVal = parseFloat(inputField.value);
            if(isNaN(typedVal)) { typedVal = parseFloat(currentVal); }

            let targetSliderVal = Math.round(typedVal * scaleFactor);
            const min = parseInt(slider.min);
            const max = parseInt(slider.max);

            if(targetSliderVal < min) targetSliderVal = min;
            if(targetSliderVal > max) targetSliderVal = max;

            slider.value = targetSliderVal;
            closeInputModal();
            updateValues();
        };
    }

    function closeInputModal() {
        document.getElementById('input-modal-overlay').style.display = 'none';
    }

    // --- 수치 피드백 및 행성 시각화 동적 렌더링 물리 엔진 ---
    function updateValues() {
        if(activeTrueEndingWatchMode) return; 

        const dist = (parseInt(document.getElementById('p-dist').value) / 100).toFixed(2);
        const temp = parseInt(document.getElementById('p-temp').value);
        const radius = (parseInt(document.getElementById('p-radius').value) / 10).toFixed(1);
        const mass = (parseInt(document.getElementById('p-mass').value) / 10).toFixed(1);
        const green = parseInt(document.getElementById('p-green').value);
        const core = parseInt(document.getElementById('p-core').value);
        const rad = parseInt(document.getElementById('p-rad').value);
        const ph = (parseInt(document.getElementById('p-ph').value) / 10).toFixed(1);
        const atm = (parseInt(document.getElementById('p-atm').value) / 100).toFixed(2);
        const o2 = parseInt(document.getElementById('p-o2').value);
        const tect = parseInt(document.getElementById('p-tect').value);
        const chiral = parseInt(document.getElementById('p-chiral').value);
        const sync = parseInt(document.getElementById('p-sync').value);
        const salt = parseInt(document.getElementById('p-salt').value);
        const water = parseInt(document.getElementById('p-water').value);
        const albedo = parseInt(document.getElementById('p-albedo').value);
        const iso = parseInt(document.getElementById('p-iso').value);
        const star = (parseInt(document.getElementById('p-star').value) / 10).toFixed(1);

        document.getElementById('lbl-dist').innerText = dist + " AU";
        document.getElementById('lbl-temp').innerText = temp + "°C";
        document.getElementById('lbl-radius').innerText = radius + " R⊕";
        document.getElementById('lbl-mass').innerText = mass + " M⊕";
        document.getElementById('lbl-green').innerText = green + "%";
        document.getElementById('lbl-core').innerText = core + "%";
        document.getElementById('lbl-rad').innerText = rad + "%";
        document.getElementById('lbl-ph').innerText = ph + " pH";
        document.getElementById('lbl-atm').innerText = atm + " atm";
        document.getElementById('lbl-o2').innerText = o2 + "%";
        document.getElementById('lbl-tect').innerText = tect + "%";
        document.getElementById('lbl-chiral').innerText = chiral + "%";
        document.getElementById('lbl-sync').innerText = sync + "%";
        document.getElementById('lbl-salt').innerText = salt + "%";
        document.getElementById('lbl-water').innerText = water + "%";
        document.getElementById('lbl-albedo').innerText = albedo + "%";
        document.getElementById('lbl-iso').innerText = iso + "%";
        document.getElementById('lbl-star').innerText = star + " M☉";

        // [시각 요소 구현 1] 반지름 연동형 실시간 크기 변동
        const mesh = document.getElementById('planet-mesh');
        let pixelSize = 80 + (radius * 12); 
        if(pixelSize < 40) pixelSize = 40;
        if(pixelSize > 250) pixelSize = 250;
        mesh.style.width = pixelSize + "px";
        mesh.style.height = pixelSize + "px";

        // [시각 요소 구현 2] 대기압 세기에 따른 주변 희뿌연 광막 두께 피드백 효과
        let blurFilter = "none";
        let glowShadow = "inset -20px -20px 60px #000";
        if(atm <= 0.1) {
            glowShadow += ", 0 0 0px rgba(0,0,0,0)";
        } else {
            let glowRadius = atm * 8; 
            if(glowRadius > 45) glowRadius = 45;
            glowShadow += `, 0 0 ${glowRadius}px rgba(0, 255, 255, ${0.1 + (atm*0.1)})`;
            if(atm >= 5.0) {
                blurFilter = `blur(${(atm - 4.5) * 0.3}px)`;
            }
        }
        mesh.style.boxShadow = glowShadow;
        mesh.style.filter = blurFilter;

        // [시각 요소 구현 3] 내부 지질 열원 폭주 시 부글부글 꿈틀대는 떨림 애니메이션 발동
        if(core >= 75) {
            mesh.classList.add('boiling');
        } else {
            mesh.classList.remove('boiling');
        }

        check30EndingsLogic(parseFloat(dist), temp, parseFloat(radius), parseFloat(mass), green, core, rad, parseFloat(ph), parseFloat(atm), o2, tect, chiral, sync, salt, water, albedo, iso, parseFloat(star));
    }

    // --- 31대 엔딩 조건 연산부 ---
    function check30EndingsLogic(dist, temp, radius, mass, green, core, rad, ph, atm, o2, tect, chiral, sync, salt, water, albedo, iso, star) {
        let triggeredKey = null;

        if (green >= 60 && dist <= 0.70 && temp >= 400 && !savedEndings.includes('end1')) { triggeredKey = 'end1'; }
        else if (radius <= 0.5 && green <= 1 && tect <= 5 && !savedEndings.includes('end2')) { triggeredKey = 'end2'; }
        else if (core <= 10 && rad >= 80 && !savedEndings.includes('end3')) { triggeredKey = 'end3'; }
        else if ((temp >= 100 || ph <= 2.0) && !savedEndings.includes('end4')) { triggeredKey = 'end4'; }
        else if (radius <= 0.3 && atm <= 0.01 && !savedEndings.includes('end5')) { triggeredKey = 'end5'; }
        else if (mass >= 10.0 && !savedEndings.includes('end6')) { triggeredKey = 'end6'; }
        else if (o2 >= 25 && !savedEndings.includes('end7')) { triggeredKey = 'end7'; }
        else if (tect === 0 && !savedEndings.includes('end8')) { triggeredKey = 'end8'; }
        else if (chiral === 50 && !savedEndings.includes('end9')) { triggeredKey = 'end9'; }
        else if (dist <= 0.10 && sync === 100 && !savedEndings.includes('end10')) { triggeredKey = 'end10'; }
        else if (salt >= 30 && !savedEndings.includes('end11')) { triggeredKey = 'end11'; }
        else if (water <= 0.01 && !savedEndings.includes('end12')) { triggeredKey = 'end12'; }
        else if (albedo >= 80 && !savedEndings.includes('end13')) { triggeredKey = 'end13'; }
        else if (iso <= 10 && !savedEndings.includes('end14')) { triggeredKey = 'end14'; }
        else if (star >= 3.0 && !savedEndings.includes('end15')) { triggeredKey = 'end15'; }
        else if (atm >= 0.9 && atm <= 1.1 && temp >= 13 && temp <= 18 && water >= 65 && water <= 75 && !savedEndings.includes('end16')) { triggeredKey = 'end16'; }
        else if (temp <= -170 && water <= 10 && green >= 40 && !savedEndings.includes('end17')) { triggeredKey = 'end17'; }
        else if (temp <= -100 && core >= 80 && !savedEndings.includes('end18')) { triggeredKey = 'end18'; }
        else if (atm >= 5.0 && temp >= -50 && temp <= -30 && !savedEndings.includes('end19')) { triggeredKey = 'end19'; }
        else if (radius >= 1.5 && atm >= 3.0 && !savedEndings.includes('end20')) { triggeredKey = 'end20'; }
        else if (star <= 0.2 && rad >= 90 && !savedEndings.includes('end21')) { triggeredKey = 'end21'; }
        else if (water >= 95 && !savedEndings.includes('end22')) { triggeredKey = 'end22'; }
        else if (dist >= 5.0 && atm >= 8.0 && !savedEndings.includes('end23')) { triggeredKey = 'end23'; }
        else if (temp >= 190 && temp <= 310 && core >= 90 && !savedEndings.includes('end24')) { triggeredKey = 'end24'; }
        else if (star >= 0.5 && star <= 0.7 && tect >= 80 && !savedEndings.includes('end25')) { triggeredKey = 'end25'; }
        else if (temp <= -25 && temp >= -35 && chiral >= 90 && !savedEndings.includes('end26')) { triggeredKey = 'end26'; }
        else if (chiral >= 95 && o2 >= 20 && o2 <= 22 && !savedEndings.includes('end27')) { triggeredKey = 'end27'; }
        else if (atm >= 6.0 && rad <= 20 && !savedEndings.includes('end28')) { triggeredKey = 'end28'; }
        else if (rad >= 95 && core >= 70 && !savedEndings.includes('end29')) { triggeredKey = 'end29'; }

        if (triggeredKey) {
            popEndingWindow(triggeredKey);
        }
    }

    let pendingResetKey = null;

    function popEndingWindow(key) {
        pendingResetKey = key;
        const data = endingRegistry[key];

        document.getElementById('end-pop-title').innerText = `🎉 연대기 해금: 엔딩 ${key.replace('end','')}`;
        document.getElementById('end-pop-desc').innerText = `${data.title}\n\n${data.desc}`;
        document.getElementById('end-pop-drake').innerText = data.drake;

        document.getElementById('ending-popup-overlay').style.display = 'flex';

        if (!savedEndings.includes(key)) {
            savedEndings.push(key);
        }
    }

    function closeEndingPopup() {
        document.getElementById('ending-popup-overlay').style.display = 'none';
        
        const data = endingRegistry[pendingResetKey];
        const mesh = document.getElementById('planet-mesh');
        mesh.style.background = data.style.background;
        mesh.style.boxShadow = data.style.boxShadow;
        document.getElementById('obs-status').innerText = `⚠️ [최근 관측]: ${data.title.split('(')[0]}`;

        // 30번 및 31번 특수 루트 판단 트리거
        if (savedEndings.length === 29 && !savedEndings.includes('end30')) {
            savedEndings.push('end30');
            
            // 만약 전구 찬스를 단 한번도 쓰지 않았다면 31번 히든 직관 엔딩도 동시 해금
            if(!hintUsed && !savedEndings.includes('end31')) {
                savedEndings.push('end31');
                alert("✨ [초특급 히든 크로니클 발생] ✨\n\n힌트를 일절 보지 않고 자력으로 도달하셨군요! 히든 엔딩 31번 [순수한 직관의 개척자] 타이틀이 추가 해금되었습니다!");
            } else {
                alert("✨ [연대기 특이점 발생] ✨\n\n29종의 하위 우주 연대기를 수집하여 '30. 가이아 네트워크'가 개방되었습니다.");
            }
        }

        silentResetEnv();
    }

    // 초기값 롤백 시 9, 16번 엔딩이 즉시 자폭 해금되는 버그 원천 차단
    function silentResetEnv() {
        document.getElementById('p-dist').value = 150;  
        document.getElementById('p-temp').value = -50;  
        document.getElementById('p-radius').value = 10; 
        document.getElementById('p-mass').value = 10;   
        document.getElementById('p-green').value = 5;   
        document.getElementById('p-core').value = 50;   
        document.getElementById('p-rad').value = 10;    
        document.getElementById('p-ph').value = 70;     
        document.getElementById('p-atm').value = 50;    // 0.50 atm으로 시작 (16번 자폭 방지)
        document.getElementById('p-o2').value = 5;      
        document.getElementById('p-tect').value = 50;   
        document.getElementById('p-chiral').value = 10;  // 10%로 시작 (9번 자폭 방지)
        document.getElementById('p-sync').value = 0;    
        document.getElementById('p-salt').value = 3;    
        document.getElementById('p-water').value = 10;   // 10%로 시작 (16번 자폭 방지)
        document.getElementById('p-albedo').value = 30;  
        document.getElementById('p-iso').value = 50;    
        document.getElementById('p-star').value = 10;   

        activeTrueEndingWatchMode = false;
        updateValues();
        refreshScoreDisplay();
    }

    // --- 연구 힌트 모듈 및 노힌트 감지 루틴 ---
    function viewHint() {
        hintUsed = true; // 힌트 사용 즉시 기록됨 (31번 락다운)
        const targetKey = document.getElementById('hint-selector').value;
        const info = endingRegistry[targetKey];
        document.getElementById('hint-display-box').innerHTML = `<strong>💡 [연구 개발 단서]</strong><br>${info.title}<br><br><span style='color:#e2e8f0;'>${info.hint}</span><br><br><span style='color:var(--danger-color); font-size:0.75rem;'>* 힌트를 열람하여 이번 회차 히든 31번 엔딩 해금 자격이 소멸되었습니다.</span>`;
    }

    // --- 공통 안내용 컨펌 팝업 ---
    function openConfirmPopup(title, msg, onYes) {
        const overlay = document.getElementById('popup-overlay');
        document.getElementById('pop-title').innerText = title;
        document.getElementById('pop-msg').innerText = msg;
        overlay.style.display = 'flex';
        
        document.getElementById('pop-yes').onclick = () => { overlay.style.display = 'none'; onYes(); };
        document.getElementById('pop-no').onclick = () => { overlay.style.display = 'none'; };
    }

    function requestGoLobby() {
        changeScreen('lobby');
    }

    function requestReset() {
        openConfirmPopup("🔄 연산 장치 초기화", "정말 행성의 모든 수치 조건을 초기 상태로 리셋하시겠습니까?", () => {
            const mesh = document.getElementById('planet-mesh');
            mesh.style.background = "radial-gradient(circle at 30% 30%, #4a5568, #2d3748, #1a202c)";
            mesh.style.boxShadow = "inset -20px -20px 60px #000, 0 0 25px rgba(255,255,255,0.08)";
            mesh.classList.remove('boiling');
            document.getElementById('obs-status').innerText = "[ 시스템 가동 중 ]: 안정한 상태";
            silentResetEnv();
        });
    }

    // --- 도감 리스트 및 미니어처 홀로그램 인형 렌더러 ---
    function openEndingBook() {
        changeScreen('book');
        const grid = document.getElementById('ending-grid-container');
        grid.innerHTML = "";

        Object.keys(endingRegistry).forEach((key, idx) => {
            const data = endingRegistry[key];
            const isUnlocked = savedEndings.includes(key);
            const isTrueEnd = (key === 'end30');
            const isHiddenEnd = (key === 'end31');

            const slot = document.createElement('div');
            let slotClass = "ending-slot";
            if(isUnlocked) {
                slotClass += " unlocked";
                if(isTrueEnd) slotClass += " true-end-slot";
                if(isHiddenEnd) slotClass += " hidden-end-slot";
            }
            slot.className = slotClass;
            slot.innerText = isUnlocked ? `🔓 [해금] 엔딩 ${idx+1}` : `🔒 미발견 연대기 ${idx+1}`;
            
            slot.onclick = () => {
                const detailBox = document.getElementById('book-detail');
                if (isUnlocked) {
                    let actionBtnHTML = "";
                    if(isTrueEnd) {
                        actionBtnHTML = `<br><button class='std-btn' style='border-color:#ff00ff; color:#ff00ff;' onclick='launchTrueEndWatch()'>가이아 네트워크 가동</button>`;
                    }
                    
                    detailBox.innerHTML = `
                        <h3 style="color:${isTrueEnd ? '#ff00ff' : (isHiddenEnd ? '#ffaa00' : 'var(--accent-color)')}; margin-bottom:10px; font-size:1.15rem;">${data.title}</h3>
                        
                        <div class="book-mini-planet" id="mini-mesh" style="display:block; background:${data.style.background}; box-shadow:${data.style.boxShadow};"></div>
                        
                        <p style="font-size:0.9rem; line-height:1.5; color:#e2e8f0; margin-bottom:15px; text-align:left;">${data.desc}</p>
                        <div style="width:100%; background:#050510; padding:10px; border-radius:5px; font-size:0.8rem; color:#4fd1c5; font-family:monospace; text-align:left;">${data.drake}</div>
                        ${actionBtnHTML}
                    `;
                } else {
                    detailBox.innerHTML = `
                        <h3 style="color:var(--muted-color); margin-bottom:12px;">🔒 기밀 프로토콜</h3>
                        <p style="color:#4a5568; font-size:0.88rem;">제어반 변수 값을 조작해 수집 라인을 개척하세요.</p>
                    `;
                }
            };
            grid.appendChild(slot);
        });
    }

    function launchTrueEndWatch() {
        activeTrueEndingWatchMode = true;
        changeScreen('game');

        const data = endingRegistry['end30'];
        const mesh = document.getElementById('planet-mesh');
        
        mesh.style.background = data.style.background;
        mesh.style.boxShadow = data.style.boxShadow;
        mesh.style.width = "180px";
        mesh.style.height = "180px";
        mesh.style.filter = "none";
        mesh.classList.remove('boiling');
        
        document.getElementById('obs-status').innerHTML = `🌌 [TRUE ENDING] : ${data.title}`;
        document.getElementById('hint-display-box').innerHTML = `<span style='color:#ff00ff; font-weight:bold;'>[연대기 마스터 완료]</span><br><br>은하 전역이 지능 매트릭스로 통합되었습니다.`;
    }

    window.onload = () => {
        const selector = document.getElementById('hint-selector');
        Object.keys(endingRegistry).forEach((key, idx) => {
            if(key !== 'end30' && key !== 'end31') { 
                const opt = document.createElement('option');
                opt.value = key;
                opt.innerText = `엔딩 ${idx+1} 힌트`;
                selector.appendChild(opt);
            }
        });

        silentResetEnv();
    };
</script>

</body>
</html>
