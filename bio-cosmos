<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bio Cosmos - 드레이크 방정식 시뮬레이터</title>
    <style>
        :root {
            --bg-color: #060613;
            --panel-color: #0f0f2d;
            --accent-color: #00ffff;
            --danger-color: #ff0055;
            --text-color: #ffffff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            user-select: none;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* 화면 세션 관리 */
        .screen {
            display: none;
            width: 100vw;
            height: 100vh;
            position: absolute;
            top: 0;
            left: 0;
        }

        .screen.active {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        /* 1. 로비 스크린 (마름모 버튼) */
        #lobby-screen h1 {
            font-size: 3rem;
            color: var(--accent-color);
            text-shadow: 0 0 20px rgba(0, 255, 255, 0.6);
            margin-bottom: 80px;
        }

        .menu-container {
            display: flex;
            gap: 60px;
        }

        .rhombus-btn {
            width: 140px;
            height: 140px;
            background: rgba(15, 15, 45, 0.8);
            border: 2px solid var(--accent-color);
            transform: rotate(45deg);
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.3s ease;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.2);
        }

        .rhombus-btn:hover {
            background: var(--accent-color);
            box-shadow: 0 0 25px var(--accent-color);
        }

        .rhombus-btn span {
            transform: rotate(-45deg);
            color: #fff;
            font-weight: bold;
            font-size: 1.1rem;
            text-align: center;
        }

        .rhombus-btn:hover span {
            color: #000;
        }

        /* 상단 네비게이션 트리거 (되돌아가기 / 리셋) */
        .nav-btn {
            position: absolute;
            top: 20px;
            width: 40px;
            height: 40px;
            background: var(--panel-color);
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            border-radius: 4px;
            font-size: 1.2rem;
            z-index: 10;
        }
        .nav-btn:hover { background: var(--accent-color); color: #000; }
        #back-btn { left: 20px; }
        #reset-btn { right: 20px; }

        /* 2. 튜토리얼 스크린 */
        .modal-content {
            background: var(--panel-color);
            border: 2px solid var(--accent-color);
            padding: 30px;
            border-radius: 12px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            box-shadow: 0 0 30px rgba(0,255,255,0.3);
        }

        .modal-content h2 { margin-bottom: 15px; color: var(--accent-color); }
        .modal-content p { font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px; color: #ccc; }
        .std-btn {
            background: transparent;
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            padding: 10px 25px;
            cursor: pointer;
            font-weight: bold;
            border-radius: 4px;
        }
        .std-btn:hover { background: var(--accent-color); color: #000; }

        /* 3. 메인 인게임 시뮬레이터 인터페이스 */
        .game-layout {
            display: grid;
            grid-template-columns: 1fr 1.2fr 1fr;
            width: 95vw;
            height: 85vh;
            gap: 20px;
            margin-top: 40px;
        }

        .game-panel {
            background: rgba(15, 15, 45, 0.6);
            border: 1px solid rgba(0, 255, 255, 0.2);
            border-radius: 8px;
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        /* 중앙 행성 구역 및 그래픽 고도화 */
        .planet-zone {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .planet-view-box {
            width: 220px;
            height: 220px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 20px;
        }

        .planet-sphere {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, #4a5568, #2d3748, #1a202c);
            box-shadow: inset -20px -20px 50px #000, 0 0 20px rgba(255,255,255,0.1);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #obs-status {
            font-weight: bold;
            color: var(--accent-color);
            text-shadow: 0 0 10px rgba(0,255,255,0.4);
            text-align: center;
        }

        /* 변수 조절 슬라이더 및 설명 버튼 */
        .section-title { font-size: 1rem; color: var(--accent-color); margin: 15px 0 10px 0; border-left: 3px solid var(--accent-color); padding-left: 8px; }
        .control-item { margin-bottom: 15px; }
        .control-header { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 5px; color: #a0aec0; }
        .slider-row { display: flex; align-items: center; gap: 8px; }
        input[type="range"] { flex: 1; accent-color: var(--accent-color); }
        .info-trigger { background: #1a1a3a; border: 1px solid #3d3d7d; color: #8f8fff; width: 22px; height: 22px; border-radius: 4px; cursor: pointer; font-size: 0.75rem; }

        /* 연구 분석 힌트 모듈 */
        .hint-select-row { display: flex; gap: 5px; margin-bottom: 15px; }
        select { flex: 1; background: #060613; border: 1px solid rgba(0,255,255,0.3); color: white; padding: 8px; border-radius: 4px; }
        .bulb-btn { background: #1a1a3a; border: 1px solid var(--accent-color); color: var(--accent-color); width: 38px; height: 38px; border-radius: 4px; cursor: pointer; font-size: 1.1rem; }

        /* 4. 엔딩북(도감) 스타일 */
        .book-container { width: 85vw; height: 75vh; display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
        .ending-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; overflow-y: auto; padding-right: 5px; }
        .ending-slot { background: #131338; border: 1px solid #2d2d5e; padding: 15px; border-radius: 6px; cursor: pointer; text-align: center; color: #718096; transition: 0.2s; }
        .ending-slot.unlocked { border-color: var(--accent-color); color: #fff; background: rgba(0,255,255,0.05); font-weight: bold; }
        .ending-detail-panel { background: rgba(15,15,45,0.8); border: 1px solid rgba(0,255,255,0.3); border-radius: 8px; padding: 20px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }

        /* 팝업 경고창 */
        .overlay { display: none; position: fixed; top:0; left:0; width:100vw; height:100vh; background: rgba(0,0,0,0.75); justify-content: center; align-items: center; z-index: 100; }
    </style>
</head>
<body>

    <div id="back-btn" class="nav-btn" onclick="requestGoLobby()" style="display: none;">◀</div>
    <div id="reset-btn" class="nav-btn" onclick="requestReset()" style="display: none;">🔄</div>

    <div id="lobby-screen" class="screen active">
        <h1>BIO COSMOS</h1>
        <div class="menu-container">
            <div class="rhombus-btn" onclick="pressStart()">
                <span>START</span>
            </div>
            <div class="rhombus-btn" onclick="openEndingBook()">
                <span>ENDING<br>BOOK</span>
            </div>
        </div>
    </div>

    <div id="tutorial-screen" class="screen">
        <div class="modal-content">
            <h2>🛸 시뮬레이션 가이드</h2>
            <p>
                '바이오 코스모스' 연구소에 오신 것을 환영합니다.<br>
                당신은 행성의 물리, 지질, 화학 변수를 조절하여 지적 생명체가 탄생할 수 있는 최적의 환경 혹은 기괴한 외계 환경 엔딩을 개척해야 합니다.<br>
                전구 모양의 힌트 모듈을 활용해 실마리를 얻고, 모든 엔딩을 해금하여 궁극의 'True 엔딩'을 달성해 보세요!
            </p>
            <button class="std-btn" onclick="exitTutorial()">시뮬레이터 접속</button>
        </div>
    </div>

    <div id="game-screen" class="screen">
        <div class="game-layout">
            
            <div class="game-panel">
                <div class="section-title">물리 및 지질 변수 조절 (ne)</div>
                
                <div class="control-item">
                    <div class="control-header"><span>표면 온도</span><span id="lbl-temp">15°C</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-temp" min="-100" max="500" value="15" oninput="updateValues()">
                        <button class="info-trigger" onclick="checkParamInfo('표면 온도', '온도는 액체 상태의 물이 존재할 수 있는 구역을 정의하며 생명 진화 속도에 핵심 영향을 줍니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>온실가스 농도</span><span id="lbl-green">10%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-green" min="0" max="100" value="10" oninput="updateValues()">
                        <button class="info-trigger" onclick="checkParamInfo('온실가스 농도', '대기 중 온실가스가 많아지면 열이 갇혀 폭주하는 온실효과 지옥이 생성될 수 있습니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>행성 질량비</span><span id="lbl-mass">1.0 M⊕</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-mass" min="1" max="100" value="10" oninput="updateValues()">
                        <button class="info-trigger" onclick="checkParamInfo('행성 질량비', '질량이 클수록 대기를 무겁게 붙잡아 강력한 중력장과 대기압을 형성합니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>자기장 보호막</span><span id="lbl-mag">50%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-mag" min="0" max="100" value="50" oninput="updateValues()">
                        <button class="info-trigger" onclick="checkParamInfo('자기장 보호막', '우주로부터 불어오는 치명적인 전리 방사선과 태양풍을 차단해 주는 방어선입니다.')">?</button>
                    </div>
                </div>

                <div class="section-title">화학 및 진화 생태계 변수</div>
                
                <div class="control-item">
                    <div class="control-header"><span>대기 내 산소 비중</span><span id="lbl-oxygen">21%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-oxygen" min="0" max="100" value="21" oninput="updateValues()">
                        <button class="info-trigger" onclick="checkParamInfo('대기 내 산소 비중', '유산소 호흡 생명체의 에너지 대사율을 결정하며, 너무 과하면 산화 폭발이 일어납니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>표면 수분 함량</span><span id="lbl-water">70%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-water" min="0" max="100" value="70" oninput="updateValues()">
                        <button class="info-trigger" onclick="checkParamInfo('표면 수분 함량', '유기물이 섞이고 세포가 보존될 수 있는 원시 바다의 면적 비율입니다.')">?</button>
                    </div>
                </div>
            </div>

            <div class="game-panel planet-zone">
                <div class="planet-view-box">
                    <div id="planet-mesh" class="planet-sphere"></div>
                </div>
                <div id="obs-status">[ 관측 진행 중 ]: 안정한 원시 행성</div>
            </div>

            <div class="game-panel">
                <div class="section-title">연구 분석 힌트 모듈</div>
                <div class="hint-select-row">
                    <select id="hint-selector">
                        <option value="end1">엔딩 1 힌트 보기</option>
                        <option value="end2">엔딩 2 힌트 보기</option>
                        <option value="end3">엔딩 3 힌트 보기</option>
                        <option value="end4">엔딩 4 힌트 보기</option>
                    </select>
                    <button class="bulb-btn" onclick="viewHint()">💡</button>
                </div>
                <div id="hint-display-box" style="font-size:0.9rem; color:#a0aec0; line-height:1.5; background:#060613; padding:12px; border-radius:6px; flex:1;">
                    힌트 대기 중... 위의 전구 단추를 누르세요.
                </div>
            </div>

        </div>
    </div>

    <div id="book-screen" class="screen">
        <h2 style="color:var(--accent-color); margin-bottom:20px;">📖 우주 생물학 연구 도감</h2>
        <div class="book-container">
            <div class="ending-grid" id="ending-grid-container">
                </div>
            <div class="ending-detail-panel" id="book-detail">
                <p style="color:#718096;">좌측의 해금된 엔딩을 선택하면 상세 정보와 달성 기록이 인쇄됩니다.</p>
            </div>
        </div>
    </div>

    <div id="popup-overlay" class="overlay">
        <div class="modal-content" style="max-width:400px;">
            <h3 id="pop-title" style="color:var(--danger-color); margin-bottom:10px;">⚠️ 경고</h3>
            <p id="pop-msg" style="margin-bottom:20px;">정말 진행하시겠습니까?</p>
            <div style="display:flex; justify-content:center; gap:15px;">
                <button class="std-btn" id="pop-yes">확인</button>
                <button class="std-btn" id="pop-no" style="border-color:#718096; color:#718096;">취소</button>
            </div>
        </div>
    </div>

<script>
    // --- 글로벌 상태 관리 엔진 ---
    let currentScreen = 'lobby';
    let isTutorialDone = false;
    
    // 유저가 도감에 영구 해금한 엔딩 키 목록
    let savedEndings = [];

    // 엔딩 데이터 정의 구조체
    const endingRegistry = {
        end1: {
            title: "🔥 폭주한 온실효과의 지옥",
            desc: "대기 중 온실가스가 극도에 달해 행성 전체가 마그마와 불바다로 뒤덮인 지옥 행성입니다.",
            condStr: "조건: 온실가스 60% 이상 & 표면 온도 400°C 이상",
            hint: "화학 계열의 '온실가스 농도'를 60% 위로 맹렬히 올리고, '표면 온도'를 400°C 이상으로 과열시키십시오.",
            style: {
                background: "radial-gradient(circle at 30% 30%, #ff3300, #ffaa00, #330000)",
                boxShadow: "inset -20px -20px 50px #000, 0 0 40px rgba(255,51,0,0.8)"
            }
        },
        end2: {
            title: "❄️ 절대영도의 심해 동결 행성",
            desc: "온도가 비정상적으로 급감하며 표면 수분이 전부 얼어붙어 모든 생체 대사가 영구 정지된 동토입니다.",
            condStr: "조건: 표면 온도 -60°C 이하 & 표면 수분 함량 80% 이상",
            hint: "'표면 온도'를 영하 -60°C 이하로 급랭시키고, '표면 수분 함량'을 80% 이상의 극대 대양 상태로 조정하세요.",
            style: {
                background: "radial-gradient(circle at 30% 30%, #a3e2f7, #3182ce, #0f172a)",
                boxShadow: "inset -20px -20px 50px #000, 0 0 40px rgba(49,130,206,0.7)"
            }
        },
        end3: {
            title: "🌳 낙원의 요람: 가이아성",
            desc: "가장 완벽한 황금대 조건이 조화를 이루어, 고도의 지능을 지닌 유기체 문명이 은하계에 탄생했습니다.",
            condStr: "조건: 온도 15~30°C & 산소 20~30% & 수분 60~80% & 자기장 60% 이상",
            hint: "지구와 유사한 환경이 답입니다. 온도는 15~30°C, 산소는 21% 내외, 수분은 60~80%, 자기장을 견고히 지키세요.",
            style: {
                background: "radial-gradient(circle at 30% 30%, #38a169, #3182ce, #1a202c)",
                boxShadow: "inset -20px -20px 50px #000, 0 0 40px rgba(56,161,105,0.7)"
            }
        },
        end4: {
            title: "👾 고농도 치사 전리 방사선 구역",
            desc: "자기장 보호막이 소멸되어 우주 방사선이 행성을 관통하면서 변이된 기괴한 기계-생명체 제국입니다.",
            condStr: "조건: 자기장 보호막 5% 이하 & 행성 질량비 80배 이상",
            hint: "'자기장 보호막' 슬라이더를 바닥(5% 이하)으로 내리고, 중력을 높이기 위해 '행성 질량비'를 80배 이상으로 과부하 하세요.",
            style: {
                background: "radial-gradient(circle at 30% 30%, #b7791f, #805ad5, #2d3748)",
                boxShadow: "inset -20px -20px 50px #000, 0 0 40px rgba(128,90,213,0.7)"
            }
        }
    };

    // --- 네비게이션 제어 코어 ---
    function changeScreen(screenName) {
        currentScreen = screenName;
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(`${screenName}-screen`).classList.add('active');

        // 버튼 상호작용 표출 여부
        const backBtn = document.getElementById('back-btn');
        const resetBtn = document.getElementById('reset-btn');

        if(screenName === 'lobby' || screenName === 'tutorial') {
            backBtn.style.display = 'none';
            resetBtn.style.display = 'none';
        } else if(screenName === 'game') {
            backBtn.style.display = 'flex';
            resetBtn.style.display = 'flex';
        } else if(screenName === 'book') {
            backBtn.style.display = 'flex';
            resetBtn.style.display = 'none';
        }
    }

    function pressStart() {
        if(!isTutorialDone) {
            changeScreen('tutorial');
        } else {
            changeScreen('game');
        }
    }

    function exitTutorial() {
        isTutorialDone = true;
        changeScreen('game');
    }

    // --- 인게임 데이터 연산 및 엔딩 감지 엔진 ---
    function updateValues() {
        const temp = parseInt(document.getElementById('p-temp').value);
        const green = parseInt(document.getElementById('p-green').value);
        const mass = parseInt(document.getElementById('p-mass').value);
        const mag = parseInt(document.getElementById('p-mag').value);
        const oxygen = parseInt(document.getElementById('p-oxygen').value);
        const water = parseInt(document.getElementById('p-water').value);

        // 라벨 실시간 연동
        document.getElementById('lbl-temp').innerText = temp + "°C";
        document.getElementById('lbl-green').innerText = green + "%";
        document.getElementById('lbl-mass').innerText = (mass/10).toFixed(1) + " M⊕";
        document.getElementById('lbl-mag').innerText = mag + "%";
        document.getElementById('lbl-oxygen').innerText = oxygen + "%";
        document.getElementById('lbl-water').innerText = water + "%";

        checkEndingConditions(temp, green, mass, mag, oxygen, water);
    }

    function checkEndingConditions(temp, green, mass, mag, oxygen, water) {
        let triggeredKey = null;

        // 엔딩 조건부 대입 
        if (green >= 60 && temp >= 400) {
            triggeredKey = 'end1';
        } else if (temp <= -60 && water >= 80) {
            triggeredKey = 'end2';
        } else if (temp >= 15 && temp <= 30 && oxygen >= 20 && oxygen <= 30 && water >= 60 && water <= 80 && mag >= 60) {
            triggeredKey = 'end3';
        } else if (mag <= 5 && mass >= 80) {
            triggeredKey = 'end4';
        }

        if (triggeredKey) {
            executeEndingTrigger(triggeredKey);
        }
    }

    // 엔딩 연출 및 리셋 연계 시스템
    function executeEndingTrigger(key) {
        const data = endingRegistry[key];
        
        // 1. 행성 그래픽 및 계측 텍스트 실시간 반영
        const mesh = document.getElementById('planet-mesh');
        mesh.style.background = data.style.background;
        mesh.style.boxShadow = data.style.boxShadow;
        document.getElementById('obs-status').innerHTML = `⚠️ [관측 완료]: ${data.title}`;

        // 2. 신규 발견 시 도감 적재
        if (!savedEndings.includes(key)) {
            savedEndings.push(key);
        }

        // 3. 엔딩 고지 후 즉시 환경 장치 초기화 (무한 루프 방지 핵심)
        setTimeout(() => {
            alert(`🎉 [엔딩 연산 성공]\n\n'${data.title}'을(를) 관측 및 영구 해금했습니다!\n확인을 누르면 환경 조건이 초기화되며 다음 탐색 모드로 전환됩니다.`);
            
            // 올컬렉션 유무 체크 후 트루엔딩 분기점 가동
            if (savedEndings.length === Object.keys(endingRegistry).length) {
                triggerTrueEnding();
            } else {
                silentResetEnv();
            }
        }, 600);
    }

    // 트루 엔딩 연출
    function triggerTrueEnding() {
        alert("✨✨ [TRUE ENDING: 생명의 마스터] ✨✨\n\n모든 변수의 특이점을 관측하여 우주의 기원을 파헤쳤습니다! 은하 연대기 데이터가 완벽하게 동기화되었습니다. 시뮬레이션을 마칩니다.");
        savedEndings = []; // 도감 리셋 후 초기 로비행
        silentResetEnv();
        changeScreen('lobby');
    }

    // 조건값 컴팩트 리셋 (도감 내역은 보존)
    function silentResetEnv() {
        document.getElementById('p-temp').value = 15;
        document.getElementById('p-green').value = 10;
        document.getElementById('p-mass').value = 10;
        document.getElementById('p-mag').value = 50;
        document.getElementById('p-oxygen').value = 21;
        document.getElementById('p-water').value = 70;
        
        // 기본 기본 원시 행성 디자인 백업
        const mesh = document.getElementById('planet-mesh');
        mesh.style.background = "radial-gradient(circle at 30% 30%, #4a5568, #2d3748, #1a202c)";
        mesh.style.boxShadow = "inset -20px -20px 50px #000, 0 0 20px rgba(255,255,255,0.1)";
        document.getElementById('obs-status').innerText = "[ 관측 진행 중 ]: 안정한 원시 행성";
        updateValues();
    }

    // --- 힌트 디스플레이어 ---
    function viewHint() {
        const targetKey = document.getElementById('hint-selector').value;
        const info = endingRegistry[targetKey];
        document.getElementById('hint-display-box').innerHTML = `<strong>💡 [분석 가이드]</strong><br><br>${info.hint}`;
    }

    function checkParamInfo(title, msg) {
        alert(`[변수 분석 툴팁 - ${title}]\n\n${msg}`);
    }

    // --- 상단 네비게이션 트리거 및 커스텀 팝업 프로토콜 ---
    function openModalPopup(title, msg, onYes) {
        const overlay = document.getElementById('popup-overlay');
        document.getElementById('pop-title').innerText = title;
        document.getElementById('pop-msg').innerText = msg;
        overlay.style.display = 'flex';
        
        document.getElementById('pop-yes').onclick = () => { overlay.style.display = 'none'; onYes(); };
        document.getElementById('pop-no').onclick = () => { overlay.style.display = 'none'; };
    }

    function requestGoLobby() {
        if(currentScreen === 'game') {
            openModalPopup("🛸 로비 이동", "메인 화면으로 복귀하시겠습니까? (기존 상태는 보존되며 재입장 시 이어하기가 가능합니다.)", () => {
                changeScreen('lobby');
            });
        } else {
            changeScreen('lobby');
        }
    }

    function requestReset() {
        openModalPopup("⚠️ 경고: 수치 초기화", "정말 행성의 모든 물리적 연산 조건을 초기 단계로 포맷하시겠습니까? (도감 해금 내역은 영구 유지됩니다.)", () => {
            silentResetEnv();
        });
    }

    // --- 엔딩 북 UI 랜더링 머신 ---
    function openEndingBook() {
        changeScreen('book');
        const grid = document.getElementById('ending-grid-container');
        grid.innerHTML = "";

        Object.keys(endingRegistry).forEach((key, idx) => {
            const data = endingRegistry[key];
            const isUnlocked = savedEndings.includes(key);
            
            const slot = document.createElement('div');
            slot.className = `ending-slot ${isUnlocked ? 'unlocked' : ''}`;
            slot.innerText = isUnlocked ? `🔓 엔딩 ${idx+1}` : `🔒 미발견 엔딩 ${idx+1}`;
            
            slot.onclick = () => {
                const detailBox = document.getElementById('book-detail');
                if (isUnlocked) {
                    detailBox.innerHTML = `
                        <h3 style="color:var(--accent-color); margin-bottom:15px;">${data.title}</h3>
                        <p style="font-size:0.95rem; line-height:1.6; color:#e2e8f0; margin-bottom:15px;">${data.desc}</p>
                        <div style="background:#060613; padding:10px; border-radius:4px; font-size:0.85rem; color:#4fd1c5; font-family:monospace;">${data.condStr}</div>
                    `;
                } else {
                    detailBox.innerHTML = `
                        <h3 style="color:#718096; margin-bottom:15px;">🔒 미지의 기록</h3>
                        <p style="color:#4a5568;">시뮬레이터를 통해 행성에 충격을 주고 특이 조건을 조합하여 이 데이터를 연독하십시오.</p>
                    `;
                }
            };
            grid.appendChild(slot);
        });
    }

    // 어플리케이션 구동 준비
    window.onload = () => {
        updateValues();
    };
</script>

</body>
</html>
