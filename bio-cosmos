<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bio Cosmos - 드레이크 방정식 시뮬레이터</title>
    <style>
        :root {
            --bg-color: #050510;
            --panel-color: #0b0b24;
            --accent-color: #00ffff;
            --danger-color: #ff0055;
            --text-color: #ffffff;
            --muted-color: #718096;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            user-select: none;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* 화면 세션 구조 */
        .screen {
            display: none;
            width: 100vw;
            height: 100vh;
            position: absolute;
            top: 0;
            left: 0;
        }

        .screen.active {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        /* 1. 로비 스크린 */
        #lobby-screen h1 {
            font-size: 3.5rem;
            color: var(--accent-color);
            text-shadow: 0 0 25px rgba(0, 255, 255, 0.6);
            margin-bottom: 90px;
            letter-spacing: 3px;
        }

        .menu-container {
            display: flex;
            gap: 70px;
        }

        .rhombus-btn {
            width: 150px;
            height: 150px;
            background: rgba(11, 11, 36, 0.9);
            border: 2px solid var(--accent-color);
            transform: rotate(45deg);
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.3s ease;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.2);
        }

        .rhombus-btn:hover {
            background: var(--accent-color);
            box-shadow: 0 0 30px var(--accent-color);
        }

        .rhombus-btn span {
            transform: rotate(-45deg);
            color: #fff;
            font-weight: bold;
            font-size: 1.15rem;
            text-align: center;
            line-height: 1.3;
        }

        .rhombus-btn:hover span {
            color: #000;
        }

        /* 네비게이션 및 간이 대시보드 */
        .nav-btn {
            position: absolute;
            top: 25px;
            width: 44px;
            height: 44px;
            background: var(--panel-color);
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            border-radius: 6px;
            font-size: 1.3rem;
            z-index: 50;
        }
        .nav-btn:hover { background: var(--accent-color); color: #000; }
        #back-btn { left: 25px; }
        #reset-btn { right: 25px; }

        .top-status-bar {
            position: absolute;
            top: 30px;
            font-size: 1.1rem;
            font-weight: bold;
            color: #fff;
            background: rgba(11, 11, 36, 0.8);
            padding: 8px 20px;
            border-radius: 20px;
            border: 1px solid rgba(0, 255, 255, 0.3);
            letter-spacing: 1px;
        }

        /* 2. 모달 / 팝업 본체 */
        .modal-content {
            background: var(--panel-color);
            border: 2px solid var(--accent-color);
            padding: 35px;
            border-radius: 14px;
            max-width: 520px;
            width: 90%;
            text-align: center;
            box-shadow: 0 0 35px rgba(0,255,255,0.4);
        }

        .modal-content h2 { margin-bottom: 18px; color: var(--accent-color); }
        .modal-content p { font-size: 0.95rem; line-height: 1.6; margin-bottom: 25px; color: #cbd5e0; }
        
        .std-btn {
            background: transparent;
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            padding: 10px 28px;
            cursor: pointer;
            font-weight: bold;
            border-radius: 5px;
            transition: 0.2s;
        }
        .std-btn:hover { background: var(--accent-color); color: #000; }

        /* 3. 인게임 레이아웃 */
        .game-layout {
            display: grid;
            grid-template-columns: 1.1fr 1fr 0.9fr;
            width: 96vw;
            height: 84vh;
            gap: 20px;
            margin-top: 60px;
        }

        .game-panel {
            background: rgba(11, 11, 36, 0.75);
            border: 1px solid rgba(0, 255, 255, 0.15);
            border-radius: 10px;
            padding: 18px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        /* 행성 실시간 그래픽 입체 연동 엔진 */
        .planet-zone {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .planet-view-box {
            width: 280px;
            height: 280px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 25px;
            position: relative;
        }

        /* 기본 구체 구조 */
        .planet-sphere {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, #4a5568, #2d3748, #1a202c);
            box-shadow: inset -20px -20px 60px #000, 0 0 20px rgba(255,255,255,0.1);
            transition: width 0.4s ease, height 0.4s ease, filter 0.3s ease, box-shadow 0.3s ease;
            position: relative;
        }

        /* 부글부글 꿈틀대는 지각 내부 마그마 모션 애니메이션 */
        @keyframes boiling-core {
            0% { transform: scale(1) translate(0, 0); filter: brightness(1); }
            33% { transform: scale(1.02) translate(1px, -1px); filter: brightness(1.1); }
            66% { transform: scale(0.99) translate(-1px, 1px); filter: brightness(0.95); }
            100% { transform: scale(1) translate(0, 0); filter: brightness(1); }
        }
        .boiling {
            animation: boiling-core 0.15s infinite linear;
        }

        #obs-status {
            font-weight: bold;
            color: var(--accent-color);
            text-shadow: 0 0 12px rgba(0,255,255,0.4);
            text-align: center;
            font-size: 1.05rem;
            margin-top: 15px;
        }

        /* 컨트롤 수치 변경 모듈 */
        .section-title { font-size: 0.95rem; color: var(--accent-color); margin: 15px 0 10px 0; border-left: 3px solid var(--accent-color); padding-left: 8px; font-weight: bold; }
        .control-item { margin-bottom: 12px; }
        .control-header { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 4px; color: #a0aec0; }
        
        /* 직접 클릭해 적을수 있는 숫자 영역 스펙 */
        .clickable-value {
            color: #fff;
            font-weight: bold;
            cursor: pointer;
            border-bottom: 1px dashed var(--accent-color);
            padding: 0 4px;
            transition: 0.2s;
        }
        .clickable-value:hover {
            color: var(--accent-color);
            background: rgba(0, 255, 255, 0.1);
        }

        .slider-row { display: flex; align-items: center; gap: 8px; }
        input[type="range"] { flex: 1; accent-color: var(--accent-color); cursor: pointer; }
        .info-trigger { background: #18183f; border: 1px solid #3b3b7a; color: #8a8aff; width: 22px; height: 22px; border-radius: 4px; cursor: pointer; font-size: 0.75rem; font-weight: bold; }

        /* 힌트 및 서브 모듈 */
        .hint-select-row { display: flex; gap: 6px; margin-bottom: 15px; }
        select { flex: 1; background: #050510; border: 1px solid rgba(0,255,255,0.25); color: white; padding: 8px; border-radius: 5px; font-size: 0.85rem; }
        .bulb-btn { background: #161644; border: 1px solid var(--accent-color); color: var(--accent-color); width: 38px; height: 38px; border-radius: 5px; cursor: pointer; font-size: 1.1rem; transition: 0.2s; }
        .bulb-btn:hover { background: var(--accent-color); color: #000; }

        /* 도감 시스템 및 홀로그램 인형 레이아웃 */
        .book-container { width: 90vw; height: 76vh; display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-top: 40px; }
        .ending-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; overflow-y: auto; padding-right: 5px; height: 68vh; }
        .ending-slot { background: #0e0e30; border: 1px solid #232352; padding: 12px; border-radius: 6px; cursor: pointer; text-align: left; font-size: 0.85rem; color: var(--muted-color); transition: 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .ending-slot.unlocked { border-color: var(--accent-color); color: #fff; background: rgba(0,255,255,0.04); font-weight: bold; }
        .ending-slot.unlocked.true-end-slot { border-color: #ff00ff; color: #ffbcff; background: rgba(255, 0, 255, 0.1); }
        .ending-slot.unlocked.hidden-end-slot { border-color: #ffaa00; color: #ffe6b3; background: rgba(255, 170, 0, 0.1); }
        
        .ending-detail-panel { background: rgba(11,11,36,0.9); border: 1px solid rgba(0,255,255,0.25); border-radius: 10px; padding: 25px; display: flex; flex-direction: column; justify-content: flex-start; align-items: center; text-align: center; height: 68vh; overflow-y: auto; }
        
        /* 도감 속 미니어처 행성 틀 */
        .book-mini-planet {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            margin: 20px 0;
            background: #4a5568;
            box-shadow: inset -10px -10px 30px #000;
            display: none;
        }

        /* 공통 백드롭 오버레이 */
        .overlay { display: none; position: fixed; top:0; left:0; width:100vw; height:100vh; background: rgba(0,0,0,0.8); justify-content: center; align-items: center; z-index: 100; }
    </style>
</head>
<body>

    <div id="back-btn" class="nav-btn" onclick="requestGoLobby()" style="display: none;">◀</div>
    <div id="current-score-board" class="top-status-bar" style="display: none;">성취도: 0 / 31</div>
    <div id="reset-btn" class="nav-btn" onclick="requestReset()" style="display: none;">🔄</div>

    <div id="lobby-screen" class="screen active">
        <h1>BIO COSMOS</h1>
        <div class="menu-container">
            <div class="rhombus-btn" onclick="pressStart()">
                <span>START</span>
            </div>
            <div class="rhombus-btn" onclick="openEndingBook()">
                <span>ENDING<br>BOOK</span>
            </div>
        </div>
    </div>

    <div id="tutorial-screen" class="screen">
        <div class="modal-content">
            <h2>🛸 시뮬레이션 환경 제어 가이드</h2>
            <p>
                '바이오 코스모스' 연구 제어반에 오신 것을 환영합니다.<br>
                화면에 배치된 거시 변수를 조작하고 수치 단위를 직접 터치해 직접 값을 적어보세요.<br>
                <strong>주의:</strong> 우측 💡힌트를 한 번도 보지 않고 독자적으로 연구를 완수하면<br>
                비밀리에 감춰진 최상위 31번째 특수 전설 연대기가 개방됩니다!
            </p>
            <button class="std-btn" onclick="exitTutorial()">방정식 시뮬레이터 가동</button>
        </div>
    </div>

    <div id="game-screen" class="screen">
        <div class="game-layout">
            
            <div class="game-panel">
                <div class="section-title">궤도 및 거시 물리 변수</div>
                
                <div class="control-item">
                    <div class="control-header"><span>항성 거리 (AU)</span><span id="lbl-dist" class="clickable-value" onclick="promptDirectInput('p-dist', '항성 거리 (0.01 ~ 5.00 AU 사이 값을 입력하세요)', 100, 2)">1.50 AU</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-dist" min="1" max="500" value="150" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('항성 거리', '모항성과 중심 행성 간의 궤도 반경입니다. 거리에 따라 도달하는 광자 에너지가 결정됩니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>표면 온도</span><span id="lbl-temp" class="clickable-value" onclick="promptDirectInput('p-temp', '표면 온도 (-200 ~ 600°C 사이 값을 입력하세요)', 1, 0)">-50°C</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-temp" min="-200" max="600" value="-50" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('표면 온도', '행성 표면의 열역학적 평균 지표 온도입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>행성 반지름 및 크기</span><span id="lbl-radius" class="clickable-value" onclick="promptDirectInput('p-radius', '행성 반지름 (0.1 ~ 30.0 R⊕ 사이 값을 입력하세요)', 10, 1)">1.0 R⊕</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-radius" min="1" max="300" value="10" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('행성 반지름', '지구 기준 대조 반지름입니다. 중력 및 그래픽 스케일 크기에 직접 동역학 기여합니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>초기 암석 핵 질량</span><span id="lbl-mass" class="clickable-value" onclick="promptDirectInput('p-mass', '암석 핵 질량 (0.1 ~ 20.0 M⊕ 사이 값을 입력하세요)', 10, 1)">1.0 M⊕</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-mass" min="1" max="200" value="10" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('초기 암석 핵 질량', '가스를 흡수하기 전 행성이 보유한 암석 중핵의 중량입니다.')">?</button>
                    </div>
                </div>

                <div class="section-title">지질 및 대기 조성 물질 제어</div>

                <div class="control-item">
                    <div class="control-header"><span>온실가스 농도</span><span id="lbl-green" class="clickable-value" onclick="promptDirectInput('p-green', '온실가스 농도 (0 ~ 100%)', 1, 0)">5%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-green" min="0" max="100" value="5" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('온실가스 농도', '이산화탄소와 메탄의 복합 대기 밀도입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>지각 내부 열원 (핵류 대류)</span><span id="lbl-core" class="clickable-value" onclick="promptDirectInput('p-core', '지각 내부 열원 (0 ~ 100%)', 1, 0)">50%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-core" min="0" max="100" value="50" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('지각 내부 열원', '다이너모 효과를 유도하는 핵의 대류 속도입니다. 높으면 행성이 부글부글 끓는 모션이 들어갑니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>우주 방사선 노출도</span><span id="lbl-rad" class="clickable-value" onclick="promptDirectInput('p-rad', '우주 방사선 (0 ~ 100%)', 1, 0)">10%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-rad" min="0" max="100" value="10" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('우주 방사선 노출도', '외부 성간 우주선 및 태양풍의 가혹한 전리 방사 강도입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>환경 산성도 (pH)</span><span id="lbl-ph" class="clickable-value" onclick="promptDirectInput('p-ph', '환경 산성도 (0.0 ~ 14.0 pH)', 10, 1)">7.0 pH</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-ph" min="0" max="140" value="70" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('환경 산성도', '수계 환경 내의 이온 농도 지수입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>대기압 (atm)</span><span id="lbl-atm" class="clickable-value" onclick="promptDirectInput('p-atm', '대기압 (0.00 ~ 10.00 atm)', 100, 2)">0.50 atm</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-atm" min="0" max="1000" value="50" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('대기압', '행성 가스가 누르는 절대 기준치입니다. 기압이 높을수록 행성 주변에 희뿌연 에어로졸 가스 광막이 연출됩니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>산소(O2) 농도 비중</span><span id="lbl-o2" class="clickable-value" onclick="promptDirectInput('p-o2', '산소 비중 (0 ~ 100%)', 1, 0)">5%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-o2" min="0" max="100" value="5" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('산소 농도 비중', '대기 중 자유 산소 분자가 차지하는 백분율입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>판구조 운동 빈도</span><span id="lbl-tect" class="clickable-value" onclick="promptDirectInput('p-tect', '판구조 운동 (0 ~ 100%)', 1, 0)">50%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-tect" min="0" max="100" value="50" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('판구조 운동', '대륙판과 해양판의 섭입 및 순환 빈도 활성도입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>카이랄성 편향성</span><span id="lbl-chiral" class="clickable-value" onclick="promptDirectInput('p-chiral', '카이랄성 편향 (0 ~ 100%)', 1, 0)">10%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-chiral" min="0" max="100" value="10" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('카이랄성 편향성', '유기 아미노산 및 당류의 광학 이성질체 비대칭도 균형입니다. (50%는 혼합물)')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>공전/자전 동기화율</span><span id="lbl-sync" class="clickable-value" onclick="promptDirectInput('p-sync', '공전/자전 동기화 (0 ~ 100%)', 1, 0)">0%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-sync" min="0" max="100" value="0" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('공전/자전 동기화율', '항성 중력에 묶여 행성의 앞뒷면이 고정되는 비율입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>해수 염도 및 증발률</span><span id="lbl-salt" class="clickable-value" onclick="promptDirectInput('p-salt', '해수 염도 (0 ~ 100%)', 1, 0)">3%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-salt" min="0" max="100" value="3" oninput="updateValues()">
                        <button class="info-trigger" onclick="openInfoModal('해수 염도', '액체 용매 내에 녹아 있는 무기 염화물 용질의 백분율 밀도입니다.')">?</button>
                    </div>
                </div>

                <div class="control-item">
                    <div class="control-header"><span>행성 총 수분량</span><span id="lbl-water" class="clickable-value" onclick="promptDirectInput('p-water', '행성 수분량 (0 ~ 100%)', 1, 0)">10%</span></div>
                    <div class="slider-row">
                        <input type="range" id="p-water" min="0" max="100" value="10" oninput="updateValues()">
