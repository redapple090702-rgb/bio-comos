    // --- 30종 방대 기계 조건 연산 필터 ---
    function check30EndingsLogic(dist, temp, radius, mass, green, core, rad, ph, atm, o2, tect, chiral, sync, salt, water, albedo, iso, star) {
        let triggeredKey = null;

        if (green >= 60 && dist <= 0.70 && temp >= 400 && !savedEndings.includes('end1')) { triggeredKey = 'end1'; }
        else if (radius <= 0.5 && green <= 1 && tect <= 5 && !savedEndings.includes('end2')) { triggeredKey = 'end2'; }
        else if (core <= 10 && rad >= 80 && !savedEndings.includes('end3')) { triggeredKey = 'end3'; }
        else if ((temp >= 100 || ph <= 2.0) && !savedEndings.includes('end4')) { triggeredKey = 'end4'; }
        else if (radius <= 0.3 && atm <= 0.01 && !savedEndings.includes('end5')) { triggeredKey = 'end5'; }
        else if (mass >= 10.0 && !savedEndings.includes('end6')) { triggeredKey = 'end6'; }
        else if (o2 >= 25 && !savedEndings.includes('end7')) { triggeredKey = 'end7'; }
        else if (tect === 0 && !savedEndings.includes('end8')) { triggeredKey = 'end8'; }
        else if (chiral === 50 && !savedEndings.includes('end9')) { triggeredKey = 'end9'; }
        else if (dist <= 0.10 && sync === 100 && !savedEndings.includes('end10')) { triggeredKey = 'end10'; }
        else if (salt >= 30 && !savedEndings.includes('end11')) { triggeredKey = 'end11'; }
        else if (water <= 0.01 && !savedEndings.includes('end12')) { triggeredKey = 'end12'; }
        else if (albedo >= 80 && !savedEndings.includes('end13')) { triggeredKey = 'end13'; }
        else if (iso <= 10 && !savedEndings.includes('end14')) { triggeredKey = 'end14'; }
        else if (star >= 3.0 && !savedEndings.includes('end15')) { triggeredKey = 'end15'; }
        else if (atm >= 0.9 && atm <= 1.1 && temp >= 13 && temp <= 18 && water >= 65 && water <= 75 && !savedEndings.includes('end16')) { triggeredKey = 'end16'; }
        else if (temp <= -170 && water <= 10 && green >= 40 && !savedEndings.includes('end17')) { triggeredKey = 'end17'; }
        else if (temp <= -100 && core >= 80 && !savedEndings.includes('end18')) { triggeredKey = 'end18'; }
        else if (atm >= 5.0 && temp >= -50 && temp <= -30 && !savedEndings.includes('end19')) { triggeredKey = 'end19'; }
        else if (radius >= 1.5 && atm >= 3.0 && !savedEndings.includes('end20')) { triggeredKey = 'end20'; }
        else if (star <= 2.0 && rad >= 90 && !savedEndings.includes('end21')) { triggeredKey = 'end21'; }
        else if (water >= 95 && !savedEndings.includes('end22')) { triggeredKey = 'end22'; }
        else if (dist >= 5.0 && atm >= 8.0 && !savedEndings.includes('end23')) { triggeredKey = 'end23'; }
        else if (temp >= 190 && temp <= 310 && core >= 90 && !savedEndings.includes('end24')) { triggeredKey = 'end24'; }
        else if (star >= 0.5 && star <= 0.7 && tect >= 80 && !savedEndings.includes('end25')) { triggeredKey = 'end25'; }
        else if (temp <= -25 && temp >= -35 && chiral >= 90 && !savedEndings.includes('end26')) { triggeredKey = 'end26'; }
        else if (chiral >= 95 && o2 >= 20 && o2 <= 22 && !savedEndings.includes('end27')) { triggeredKey = 'end27'; }
        else if (atm >= 6.0 && rad <= 20 && !savedEndings.includes('end28')) { triggeredKey = 'end28'; }
        else if (rad >= 95 && core >= 70 && !savedEndings.includes('end29')) { triggeredKey = 'end29'; }

        if (triggeredKey) {
            popEndingWindow(triggeredKey);
        }
    }

    // --- 중앙 팝업창 형식 엔딩 발동기 ---
    let pendingResetKey = null;

    function popEndingWindow(key) {
        pendingResetKey = key;
        const data = endingRegistry[key];

        document.getElementById('end-pop-title').innerText = `🎉 연대기 해금: 엔딩 ${key.replace('end','')}`;
        document.getElementById('end-pop-desc').innerText = `${data.title}\n\n${data.desc}`;
        document.getElementById('end-pop-drake').innerText = data.drake;

        document.getElementById('ending-popup-overlay').style.display = 'flex';

        if (!savedEndings.includes(key)) {
            savedEndings.push(key);
        }
    }

    function closeEndingPopup() {
        document.getElementById('ending-popup-overlay').style.display = 'none';
        
        const data = endingRegistry[pendingResetKey];
        const mesh = document.getElementById('planet-mesh');
        mesh.style.background = data.style.background;
        mesh.style.boxShadow = data.style.boxShadow;
        document.getElementById('obs-status').innerText = `⚠️ [최근 관측]: ${data.title.split('(')[0]}`;

        if (savedEndings.length === 29 && !savedEndings.includes('end30')) {
